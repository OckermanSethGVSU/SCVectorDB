PLATFORM=AURORA
RUN_MODE=PBS
TASK=QUERY
ENGINE=milvus
MODE=DISTRIBUTED
ENV_PATH=/path/to/env
STORAGE_MEDIUM=lustre



ACCOUNT=<ACCOUNT>
WALLTIME=01:00:00
QUEUE=debug-scaling



DISTANCE_METRIC=COSINE
HNSW_M=16
HNSW_EF_CONSTRUCTION=100


# Modify to recreate experiments
INSERT_DATA_FILEPATH=/path/to/pes2o/NpyFile
VECTOR_DIM=2560

QUERY_DATA_FILEPATH=/path/to/pes2o/QueryNpyFile
QUERY_BATCH_SIZE=32

NODES=1
QUERY_NODES=1
QUERY_NODES_PER_CN=1
NUM_PROXIES=1
NUM_PROXIES_PER_CN=1