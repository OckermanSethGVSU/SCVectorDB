
RUN_MODE=PBS
TASK=INDEX
ENGINE=milvus
MODE=STANDALONE
ENV_PATH=/path/to/env

STORAGE_MEDIUM=memory
NODES=1


ACCOUNT=<ACCOUNT>
WALLTIME=01:00:00
QUEUE=debug-scaling



INSERT_DATA_FILEPATH=/path/to/pes2o/NpyFile
VECTOR_DIM=2560
DISTANCE_METRIC=COSINE
HNSW_M=16
HNSW_EF_CONSTRUCTION=100


# Modify to recreate experiments
PLATFORM=AURORA
GPU_INDEX=False
CORES=64
INSERT_CORPUS_SIZE=1000000