
RUN_MODE=PBS
TASK=INSERT
ENGINE=milvus
ENV_PATH=/path/to/env


ACCOUNT=<ACCOUNT>
WALLTIME=01:00:00
QUEUE=debug-scaling

LOG_LEVEL=ERROR

INSERT_DATA_FILEPATH=/path/to/pes2o/NpyFile
VECTOR_DIM=2560
DISTANCE_METRIC=COSINE
HNSW_M=16
HNSW_EF_CONSTRUCTION=100


# Modify to recreate experiments
PLATFORM=AURORA
MODE=STANDALONE
STORAGE_MEDIUM=memory
NODES=1

INSERT_BATCH_SIZE=32

# Distributed specific vars
# INSERT_CLIENTS_PER_PROXY=1
# MODE=DISTRIBUTED
# STORAGE_MEDIUM=lustre
# STREAMING_NODES=4
# STREAMING_NODES_PER_CN=4
# NUM_PROXIES=4
# NUM_PROXIES_PER_CN=4