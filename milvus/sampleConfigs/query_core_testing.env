PLATFORM=AURORA
RUN_MODE=PBS
TASK=QUERY
ENGINE=milvus
MODE=STANDALONE
ENV_PATH=/path/to/env

STORAGE_MEDIUM=memory
NODES=1


ACCOUNT=<ACCOUNT>
WALLTIME=01:00:00
QUEUE=debug-scaling



DISTANCE_METRIC=COSINE
HNSW_M=16
HNSW_EF_CONSTRUCTION=100
INSERT_CORPUS_SIZE=10000000

# Modify to recreate experiments
QUERY_BATCH_SIZE=32
INSERT_DATA_FILEPATH=/path/to/pes2o/NpyFile
QUERY_DATA_FILEPATH=/path/to/pes2o/QueryNpyFile
VECTOR_DIM=2560
CORES=64
