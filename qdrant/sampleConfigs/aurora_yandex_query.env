# Qdrant Aurora query run template.
# Generate with:
# ./pbs_submit_manager.sh --generate-only --config qdrant/aurora_query.env
# Submit by removing --generate-only once the paths and account settings are filled.

ENGINE=qdrant
TASK=QUERY
RUN_MODE=PBS
PLATFORM=AURORA

# PBS settings to fill in.
ACCOUNT=radix-io
WALLTIME=01:00:00
QUEUE=debug-scaling

# Preferred: set ENV_PATH to the Python environment root.
# If the loaded modules/current Python already have all required dependencies, leave ENV_PATH
# empty and set ALLOW_SYSTEM_PYTHON=True.
ENV_PATH=/lus/flare/projects/radix-io/sockerman/temp/qdrant/newEnv/

# Cluster sizing.
NODES=1
WORKERS_PER_NODE=1
STORAGE_MEDIUM=memory
CORES=

# Qdrant runtime.
QDRANT_SIF=qdrant_v1.16.1.sif
LOG_LEVEL=ERROR

# Dataset and query paths to fill in.
INSERT_DATA_FILEPATH=/lus/flare/projects/AuroraGPT/sockerman/text2image1B/Yandex10M.npy
QUERY_DATA_FILEPATH=/lus/flare/projects/AuroraGPT/sockerman/text2image1B/YandexQuery100k.npy

# Data shape and metric.
VECTOR_DIM=200
DISTANCE_METRIC=IP

# Query controls.
QUERY_BATCH_SIZE=32
QUERY_BALANCE_STRATEGY=NO_BALANCE
QUERY_CLIENTS_PER_WORKER=1
TOTAL_QUERY_CLIENTS=1

# Index/runtime options.
HNSW_M=16
HNSW_EF_CONSTRUCTION=100
