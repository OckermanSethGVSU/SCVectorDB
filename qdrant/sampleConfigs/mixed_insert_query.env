PLATFORM=AURORA
RUN_MODE=PBS
TASK=QUERY
ENGINE=qdrant
ENV_PATH=/path/to/env

STORAGE_MEDIUM=memory
NODES=1


ACCOUNT=<ACCOUNT>
WALLTIME=01:00:00
QUEUE=debug-scaling



HNSW_M=16
HNSW_EF_CONSTRUCTION=100

QUERY_MODE=MAX
MIXED_QUERY_BATCH_SIZE=32

INSERT_MODE=MAX
MIXED_INSERT_BATCH_SIZE=32

# Modify to recreate experiments
INSERT_DATA_FILEPATH=/path/to/NpyFilePart1 #  5 million subset of data to be inserted prior to experiment
DISTANCE_METRIC=COSINE
VECTOR_DIM=2560
MIXED_DATA_FILEPATH=/path/to/NpyFilePart2 # 5 million subset of data inserted during queries
QUERY_DATA_FILEPATH=/path/to/NpyQueryFile

