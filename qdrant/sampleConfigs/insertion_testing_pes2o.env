
RUN_MODE=PBS
TASK=INSERT
ENGINE=qdrant
ENV_PATH=/path/to/env


ACCOUNT=<ACCOUNT>
WALLTIME=01:00:00
QUEUE=debug-scaling


QDRANT_SIF=qdrant_v1.16.1.sif
LOG_LEVEL=ERROR

INSERT_DATA_FILEPATH=/path/to/pes2o/NpyFile
VECTOR_DIM=2560
DISTANCE_METRIC=COSINE
HNSW_M=16
HNSW_EF_CONSTRUCTION=100


# Modify to recreate experiments
PLATFORM=AURORA
STORAGE_MEDIUM=memory
NODES=1
WORKERS_PER_NODE=1

INSERT_BATCH_SIZE=32
INSERT_CLIENTS_PER_WORKER=1