# Aurora query run template.

ENGINE=weaviate
TASK=QUERY
RUN_MODE=PBS
PLATFORM=AURORA

ACCOUNT=<ACCOUNT>
WALLTIME=01:00:00
QUEUE=debug-scaling


ENV_PATH=/path/to/env

QDRANT_SIF=qdrant_v1.16.1.sif
HNSW_M=16
HNSW_EF_CONSTRUCTION=100
QUERY_BATCH_SIZE=32
VECTOR_DIM=2560
DISTANCE_METRIC=COSINE

# Modify to recreate experiments
NODES=8
WORKERS_PER_NODE=4
INSERT_DATA_FILEPATH=/path/to/npy
QUERY_DATA_FILEPATH=/path/to/queryNpy