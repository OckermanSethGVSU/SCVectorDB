# Weaviate Aurora query_scaling template for pes2o embeddings.
# Generate a run dir with:
#   ./pbs_submit_manager.sh --generate-only --engine weaviate \
#       --config weaviate/sampleConfigs/aurora_pes2o_query_scaling.env
# Submit by removing --generate-only once the paths and account settings are filled.

ENGINE=weaviate
TASK=QUERY_SCALING
RUN_MODE=PBS
PLATFORM=AURORA

# PBS settings to fill in.
ACCOUNT=radix-io
WALLTIME=01:00:00
QUEUE=debug-scaling

# Cluster sizing.
NODES=1
WORKERS_PER_NODE=4
CORES=112
STORAGE_MEDIUM=memory

# Dataset.
DATASET_LABEL=pes2o
CLASS_NAME=PES2OEF64
VECTOR_DIM=2560
DISTANCE_METRIC=COSINE

INSERT_DATA_FILEPATH=/lus/flare/projects/AuroraGPT/sockerman/pes2oEmbeddings/embeddings.npy
QUERY_DATA_FILEPATH=/lus/flare/projects/AuroraGPT/sockerman/pes2oEmbeddings/queries.npy

# Insert phase controls.
INSERT_CORPUS_SIZE=10000000
INSERT_BATCH_SIZE=2048
INSERT_CLIENTS_PER_WORKER=16
INSERT_BALANCE_STRATEGY=WORKER_BALANCE

# Query phase controls.
QUERY_CORPUS_SIZE=100000
QUERY_BATCH_SIZE=256
QUERY_TOPK=10
QUERY_EF=64
QUERY_CLIENTS_PER_WORKER=1
QUERY_CLIENT_MODE=per_worker

# Client binaries (built under weaviate/clients/*/).
INSERT_BIN=insert_streaming
QUERY_SCALING_BIN=query
