# Aurora query run template.

ENGINE=weaviate
TASK=QUERY
RUN_MODE=PBS
PLATFORM=AURORA

ACCOUNT=<ACCOUNT>
WALLTIME=01:00:00
QUEUE=debug-scaling


ENV_PATH=/path/to/env

HNSW_M=16
HNSW_EF_CONSTRUCTION=100

# Modify to recreate experiments
CORES=32
INSERT_DATA_FILEPATH=/path/to/npy
VECTOR_DIM=200
DISTANCE_METRIC=IP

QUERY_DATA_FILEPATH=/path/to/queryNpy
QUERY_BATCH_SIZE=32