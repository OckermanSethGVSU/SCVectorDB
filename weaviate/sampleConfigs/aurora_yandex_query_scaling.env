# Weaviate Aurora query_scaling template for Yandex text2image embeddings.
# Generate a run dir with:
#   ./pbs_submit_manager.sh --generate-only --engine weaviate \
#       --config weaviate/sampleConfigs/aurora_yandex_query_scaling.env

ENGINE=weaviate
TASK=query_scaling
RUN_MODE=PBS
PLATFORM=AURORA

# PBS settings to fill in.
ACCOUNT=radix-io
WALLTIME=01:00:00
QUEUE=debug-scaling

# Cluster sizing.
NODES=1
WORKERS_PER_NODE=4
CORES=112
STORAGE_MEDIUM=memory

# Dataset.
DATASET_LABEL=yandex
CLASS_NAME=YandexT2I
VECTOR_DIM=200
DISTANCE_METRIC=DOT

INSERT_DATA_FILEPATH=/lus/flare/projects/AuroraGPT/sockerman/text2image1B/Yandex10M.npy
QUERY_FILEPATH=/lus/flare/projects/AuroraGPT/sockerman/text2image1B/YandexQuery100k.npy

# Insert phase controls.
INSERT_CORPUS_SIZE=10000000
INSERT_BATCH_SIZE=2048
INSERT_CLIENTS_PER_WORKER=16
INSERT_BALANCE_STRATEGY=WORKER_BALANCE

# Query phase controls.
QUERY_WORKLOAD=100000
QUERY_BATCH_SIZE=32
QUERY_TOPK=10
QUERY_EF=64
QUERY_CLIENTS_PER_WORKER=1
QUERY_CLIENT_MODE=per_worker

# Client binaries (built under weaviate/clients/*/).
INSERT_BIN=insert_streaming
QUERY_SCALING_BIN=query
